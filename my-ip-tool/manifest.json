{
	"manifest_version": 3,
	"name": "My IP Tool",
	"short_name": "My IP",
	"version": "1.1.2",
	"action": {
		"default_icon": {
			"16": "icons/icon16.png",
			"48": "icons/icon48.png"
		},
		"default_popup": "popup.html"
	},
	"icons": {
		"16": "icons/icon16.png",
		"48": "icons/icon48.png",
		"128": "icons/icon128.png"
	},
	"host_permissions": [
		"https://my-ip.lyuwenhan.workers.dev/*"
	],
	"description": "Quickly view your public IP address in a clean popup."
}
